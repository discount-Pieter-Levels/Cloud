# Node-based Dockerfile for the frontend and API server
FROM node:20-slim AS builder
WORKDIR /app

COPY package.json ./
RUN npm install

COPY tsconfig.json vite.config.ts script ./
COPY client ./client
COPY server ./server
COPY shared ./shared

RUN npm run build

FROM node:20-slim AS runtime
WORKDIR /app
COPY package.json ./
RUN npm install --omit=dev

COPY --from=builder /app/dist ./dist

EXPOSE 5000
ENV NODE_ENV=production
CMD ["node", "dist/index.cjs"]
